<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bearing QR Generator</title>

<script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>

<style>

body{
    font-family:Arial;
    background:#f2f4f8;
    padding:40px;
}

.container{
    width:500px;
    margin:auto;
    background:#ffffff;
    padding:30px;
    border-radius:10px;
    box-shadow:0 0 10px #cccccc;
}

h1{
    text-align:center;
    color:#003366;
}

input{
    width:250px;
    padding:10px;
    font-size:16px;
}

button{
    padding:10px 20px;
    background:#003366;
    color:white;
    border:none;
    cursor:pointer;
}

button:hover{
    background:#00509e;
}

#qrcode{
    margin-top:20px;
}

#url{
    margin-top:20px;
    word-break:break-all;
    color:#003366;
}

</style>

</head>

<body>

<div class="container">

<h1>Bearing QR Generator</h1>

<label>Enter Bearing ID</label>

<br><br>

<input
type="number"
id="bearingId"
placeholder="Example : 1">

<button onclick="generateQR()">
Generate QR
</button>

<br><br>

<canvas id="qrcode"></canvas>

<div id="url"></div>

</div>

<script>

function generateQR(){

    const id =
    document.getElementById("bearingId").value.trim();

    if(id===""){

        alert("Please Enter Bearing ID");

        return;

    }

    const qrUrl =
    "https://llbi-1.github.io/Bearing_QR_System/?id=" + id;

    QRCode.toCanvas(

        document.getElementById("qrcode"),

        qrUrl,

        function(error){

            if(error){

                console.error(error);

            }

        }

    );

    document.getElementById("url").innerHTML =
    "<b>QR URL:</b><br>" + qrUrl;

}

</script>

</body>
</html>
