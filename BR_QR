<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<title>Bearing QR Generator</title>


<!-- Supabase Library -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>


<!-- QR Code Library -->
<script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>


<style>

body{

    font-family: Arial, sans-serif;
    background:#f4f4f4;
    padding:40px;

}


.container{

    width:500px;
    margin:auto;
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0px 0px 10px #ccc;

}


h1{

    color:#003366;
    text-align:center;

}


input{

    width:300px;
    padding:10px;
    font-size:16px;

}


button{

    padding:10px 20px;
    background:#003366;
    color:white;
    border:none;
    cursor:pointer;

}


button:hover{

    background:#00509e;

}


#qrcode{

    margin-top:30px;

}


</style>


</head>



<body>


<div class="container">


<h1>Bearing QR Generator</h1>


<br>


<label>
Enter Bearing Serial Number
</label>


<br><br>


<input 
type="text"
id="serial"
placeholder="Example: BRG001">



<button onclick="generateQR()">

Generate QR

</button>



<br><br>


<canvas id="qrcode"></canvas>



</div>




<script>


// Supabase Connection

const supabaseUrl =
"https://xuladkirdleczvqlvkzr.supabase.co";


const supabaseKey =
"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh1bGFka2lyZGxlY3p2a3pyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ2OTA5MDgsImV4cCI6MjEwMDI2NjkwOH0.tqLHurcorsedBgPEoeynwmajCJox4tXMfECkxhxwLiU";



const client =
supabase.createClient(
supabaseUrl,
supabaseKey
);




// Generate QR Function

async function generateQR(){


const serial =
document.getElementById("serial").value.trim();



if(serial===""){

alert("Please Enter Serial Number");

return;

}




const {data,error}=await client

.from("Bearing_tracebility")

.select("*")

.eq("serial_number",serial);



if(error){

alert(error.message);

return;

}




if(data.length===0){

alert("Bearing Not Found");

return;

}



const b=data[0];




// IMPORTANT QR URL

const qrData =

"https://llbi-1.github.io/Bearing_QR_System/?sn="

+

encodeURIComponent(b.serial_number);





QRCode.toCanvas(

document.getElementById("qrcode"),

qrData,

function(error){

    if(error){

        console.error(error);

    }

}


);



}


</script>


</body>

</html>
