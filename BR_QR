<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<title>Bearing QR Generator</title>


<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>


<style>

body{

    font-family: Arial;
    background:#f4f4f4;
    padding:40px;

}


.container{

    width:500px;
    margin:auto;
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0px 0px 10px #ccc;

}


h1{

    text-align:center;
    color:#003366;

}


input{

    width:300px;
    padding:10px;
    font-size:16px;

}


button{

    padding:10px 20px;
    background:#003366;
    color:white;
    border:none;
    cursor:pointer;

}


#message{

    margin-top:20px;
    color:red;

}


#qrcode{

    margin-top:20px;

}


</style>


</head>



<body>


<div class="container">


<h1>Bearing QR Generator</h1>


<br>


<label>
Enter Bearing Serial Number
</label>


<br><br>


<input 
type="text"
id="serial"
placeholder="Example: BRG001">


<button onclick="generateQR()">
Generate QR
</button>



<div id="message"></div>


<br>


<canvas id="qrcode"></canvas>


</div>





<script>


// SUPABASE CONNECTION

const supabaseUrl =
"https://xuladkirdleczvqlvkzr.supabase.co";


const supabaseKey =
"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh1bGFka2lyZGxlY3p2bHF2a3pyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ2OTA5MDgsImV4cCI6MjEwMDI2NjkwOH0.tqLHurcorsedBgPEoeynwmajCJox4tXMfECkxhxwLiU";


const client =
supabase.createClient(
    supabaseUrl,
    supabaseKey
);




// GENERATE QR

async function generateQR(){


let serial =
document.getElementById("serial").value.trim();



if(serial==""){

document.getElementById("message").innerHTML =
"Enter Serial Number";

return;

}




const {data,error}=await client

.from("Bearing_tracebility")

.select("*")

.eq("serial_number",serial);



if(error){

document.getElementById("message").innerHTML =
error.message;

return;

}




if(data.length==0){

document.getElementById("message").innerHTML =
"Bearing Not Found";

return;

}




let bearing=data[0];



// QR CONTENT

let qrData =
"https://llbi-1.github.io/Bearing_QR_System/?sn="
+
encodeURIComponent(bearing.serial_number);





QRCode.toCanvas(

document.getElementById("qrcode"),

qrData,

function(error){

if(error){

console.log(error);

}

}

);



document.getElementById("message").innerHTML =
"QR Generated Successfully";



}



</script>


</body>

</html>
