<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bearing QR Generator</title>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>

    <style>
        body{
            font-family:Arial, Helvetica, sans-serif;
            background:#f2f4f8;
            padding:40px;
        }

        .container{
            width:700px;
            max-width:95%;
            margin:auto;
            background:#fff;
            padding:30px;
            border-radius:10px;
            box-shadow:0 4px 15px rgba(0,0,0,.15);
        }

        h1{
            text-align:center;
            color:#003366;
            margin-bottom:30px;
        }

        input{
            width:300px;
            padding:10px;
            font-size:16px;
        }

        button{
            padding:10px 20px;
            background:#003366;
            color:#fff;
            border:none;
            cursor:pointer;
        }

        button:hover{
            background:#00509e;
        }

        #result{
            margin-top:20px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        th,td{
            border:1px solid #ccc;
            padding:10px;
        }

        th{
            background:#003366;
            color:#fff;
        }

        #qrcode{
            margin-top:20px;
        }

        .url{
            margin-top:15px;
            word-break:break-all;
            color:#003366;
        }
    </style>
</head>

<body>

<div class="container">

    <h1>Bearing QR Generator</h1>

    <input
        type="text"
        id="serial"
        placeholder="Enter Serial Number">

    <button onclick="generateQR()">
        Generate QR
    </button>

    <div id="result"></div>

    <canvas id="qrcode"></canvas>

    <div id="url" class="url"></div>

</div>

<script>

const supabaseUrl =
"https://xuladkirdleczvqlvkzr.supabase.co";

const supabaseKey =
"YOUR_ANON_PUBLIC_KEY";

const client =
supabase.createClient(
    supabaseUrl,
    supabaseKey
